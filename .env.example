# PostgreSQL connection string. On Railway this is auto-injected when the
# Postgres service is linked to this app service (e.g. ${{Postgres.DATABASE_URL}}).
# Debe ser un rol con permisos de DDL: lo usan las migraciones y el cliente
# "system" (auth, superadmin, crons — ver src/lib/prisma.ts).
DATABASE_URL="postgresql://user:password@localhost:5432/crm_zalantos"

# Opcional: URL separada para el cliente system si querés un rol distinto al
# de DATABASE_URL. Si no se define, el cliente system usa DATABASE_URL.
# DATABASE_URL_SYSTEM="postgresql://crm_owner:password@localhost:5432/crm_zalantos"

# Conexión de bajo privilegio (rol crm_app, NOBYPASSRLS, sin DDL) para el
# tráfico de tenant. Habilita Row Level Security como segunda barrera de
# aislamiento multi-tenant. Crear el rol con scripts/sql/setup-roles.sql
# ANTES de aplicar la migración enable_row_level_security. Si no se define,
# el tráfico de tenant corre con el mismo rol que DATABASE_URL (RLS queda
# inactiva porque el owner la bypassea; el aislamiento sigue garantizado por
# el filtro de app en src/lib/tenant.ts).
# TENANT_DATABASE_URL="postgresql://crm_app:password@localhost:5432/crm_zalantos"

# Tamaño del pool de conexiones del cliente system. Default: 5.
# SYSTEM_DB_POOL_MAX="5"

# Tamaño del pool de conexiones del cliente de tenant. Con RLS activa cada
# operación abre una transacción de 2 statements (ver src/lib/tenant.ts), así
# que debe cubrir el fan-out de Promise.all más grande de la app (~12 en el
# dashboard). Default: 15.
# TENANT_DB_POOL_MAX="15"

# Auth.js secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand--base64-32"

# Required on Railway (and any host behind a reverse proxy) so Auth.js v5
# trusts the forwarded Host header. Without this, sign-in fails in production.
AUTH_TRUST_HOST="true"

# Only needed if AUTH_TRUST_HOST is not enough for your setup (e.g. custom
# domain not detected automatically). Must match the public URL of the app.
# AUTH_URL="https://your-app.up.railway.app"

# Shared secret required in the Authorization header of the overdue-check
# cron endpoint. Must be a real random value — the endpoint rejects known
# placeholder values and anything shorter than 16 characters.
CRON_SECRET="replace-with-a-random-string"

# Credentials for the admin user created by `prisma db seed`. If either is
# missing, the seed skips admin creation with a warning instead of failing.
# Never run the seed against a production database.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# ---------- Meeting Intelligence ----------

# Groq API key — used for BOTH audio transcription (whisper-large-v3) and the
# CRM reasoning step (llama-3.3-70b-versatile). One key, two jobs.
GROQ_API_KEY="gsk_..."
# Optional model overrides (defaults shown).
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3"
GROQ_REASONING_MODEL="llama-3.3-70b-versatile"

# Cloudflare R2 (S3-compatible) — evidence storage. Create an R2 bucket and an
# API token with Object Read & Write. The endpoint is
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID="replace-me"
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"
R2_BUCKET="crm-zalantos-evidence"

# Public base URL of this app, used to build the internal pipeline callback
# (e.g. https://your-app.up.railway.app). Falls back to AUTH_URL / localhost.
APP_URL="http://localhost:3000"

# Clave AES-256-GCM (32 bytes en base64 o hex) para cifrar secretos por
# organización (ej. integrationGatewaySecret). Requerida si alguna org
# configura gateway propio en admin. Generar con: openssl rand -base64 32
# SETTINGS_ENCRYPTION_KEY="replace-with-32-byte-key"

# ---------- Integration Gateway ----------

# Single external webhook used by the CRM integration gateway. The CRM owns all
# business logic, dedupe and audit; this URL receives delivery commands for
# external providers. The secret is sent in the x-webhook-secret header.
INTEGRATION_GATEWAY_URL="https://your-automation-host/webhook/crm-gateway"
INTEGRATION_GATEWAY_SECRET="replace-with-a-random-string"

# ---------- Agente IA (copiloto) ----------
# Modelo del agente de chat: "proveedor/modelo" (groq | anthropic | openai).
# Default: groq/GROQ_REASONING_MODEL. Recomendado en producción:
# AGENT_MODEL="anthropic/claude-sonnet-4-5" (requiere ANTHROPIC_API_KEY).
# AGENT_MODEL="groq/llama-3.3-70b-versatile"
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# Modelo de razonamiento del análisis de reuniones (independiente del agente).
# Default: groq/GROQ_REASONING_MODEL.
# MEETING_REASONING_MODEL="anthropic/claude-sonnet-4-5"
