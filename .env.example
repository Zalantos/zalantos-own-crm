# PostgreSQL connection string. On Railway this is auto-injected when the
# Postgres service is linked to this app service (e.g. ${{Postgres.DATABASE_URL}}).
DATABASE_URL="postgresql://user:password@localhost:5432/crm_zalantos"

# Auth.js secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand--base64-32"

# Required on Railway (and any host behind a reverse proxy) so Auth.js v5
# trusts the forwarded Host header. Without this, sign-in fails in production.
AUTH_TRUST_HOST="true"

# Only needed if AUTH_TRUST_HOST is not enough for your setup (e.g. custom
# domain not detected automatically). Must match the public URL of the app.
# AUTH_URL="https://your-app.up.railway.app"

# Shared secret required in the Authorization header of the overdue-check
# cron endpoint. Must be a real random value — the endpoint rejects known
# placeholder values and anything shorter than 16 characters.
CRON_SECRET="replace-with-a-random-string"

# Credentials for the admin user created by `prisma db seed`. If either is
# missing, the seed skips admin creation with a warning instead of failing.
# Never run the seed against a production database.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# ---------- Meeting Intelligence ----------

# Groq API key — used for BOTH audio transcription (whisper-large-v3) and the
# CRM reasoning step (llama-3.3-70b-versatile). One key, two jobs.
GROQ_API_KEY="gsk_..."
# Optional model overrides (defaults shown).
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3"
GROQ_REASONING_MODEL="llama-3.3-70b-versatile"

# Cloudflare R2 (S3-compatible) — evidence storage. Create an R2 bucket and an
# API token with Object Read & Write. The endpoint is
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID="replace-me"
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"
R2_BUCKET="crm-zalantos-evidence"

# Public base URL of this app, used to build the internal pipeline callback
# (e.g. https://your-app.up.railway.app). Falls back to AUTH_URL / localhost.
APP_URL="http://localhost:3000"
