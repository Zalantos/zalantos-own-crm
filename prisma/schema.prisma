generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum EntityType {
  company
  person
  opportunity
  activity
  note
  meeting
}

// ---------- Meeting Intelligence ----------

enum ProcessingStatus {
  pending
  extracting
  transcribing
  analyzing
  ready
  failed
}

enum ProposalStatus {
  pending
  approved
  rejected
  partially_approved
  applied
}

enum CustomFieldType {
  text
  number
  boolean
  date
  select
  multiselect
}

enum Role {
  ADMIN
  MEMBER
}

// ---------- Multi-tenancy ----------

// Cada empresa cliente del SaaS. Los settings viven inline (pocos campos,
// sin billing) para evitar un join extra por request.
model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  currency    String  @default("CLP") // ISO 4217
  timezone    String  @default("America/Santiago") // IANA
  locale      String  @default("es-CL") // BCP 47, solo afecta formateo Intl
  brandName   String? // fallback: name
  logoUrl     String?
  accentColor String  @default("#0f766e")

  // Gateway de integraciones por org; si es null se usa el env global.
  integrationGatewayUrl    String?
  // Cifrado AES-256-GCM con SETTINGS_ENCRYPTION_KEY; nunca se muestra en UI.
  integrationGatewaySecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  pipelineStages         PipelineStage[]
  invitations            Invitation[]
  passwordResetTokens    PasswordResetToken[]
  companies              Company[]
  people                 Person[]
  opportunities          Opportunity[]
  activities             Activity[]
  notes                  Note[]
  savedViews             SavedView[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  workflows              Workflow[]
  workflowLogs           WorkflowLog[]
  integrationDeliveries  IntegrationDelivery[]
  teamMembers            TeamMember[]
  meetings               Meeting[]
  evidence               Evidence[]
  changeProposals        CRMChangeProposal[]
  changeItems            CRMChangeItem[]
  agentChatThreads       AgentChatThread[]
  agentChatMessages      AgentChatMessage[]
  agentAttachments       AgentAttachment[]
  timelineEvents         TimelineEvent[]
  entityContextSources   EntityContextSource[]
  entityContextProfiles  EntityContextProfile[]
  telegramLinks          TelegramLink[]
  telegramLinkCodes      TelegramLinkCode[]

  @@map("organizations")
}

// Etapas del pipeline configurables por organización (reemplaza al enum
// OpportunityStage). `key` es un slug estable que usan el agente y webhooks.
model PipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  label          String
  sortOrder      Int
  color          String?
  isWon          Boolean      @default(false)
  isLost         Boolean      @default(false)
  // Retirar en vez de borrar cuando la etapa tiene oportunidades.
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  opportunities Opportunity[]

  @@unique([organizationId, key])
  @@unique([organizationId, sortOrder])
  @@index([organizationId])
  @@map("pipeline_stages")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role         @default(MEMBER)
  // sha256 del token; el token crudo solo se muestra/envía una vez.
  tokenHash      String       @unique
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([organizationId, email])
  @@map("invitations")
}

model PasswordResetToken {
  id             String        @id @default(cuid())
  // Nullable: los super-admins sin org también pueden resetear password.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String        @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------- Core CRM entities ----------

model Company {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name            String
  website         String?
  industry        String?
  size            String?
  country         String?
  city            String?
  linkedinUrl     String?
  description     String?      @db.Text
  icpScore        Int?
  fitScore        Int?
  painScore       Int?
  status          String       @default("active")
  source          String?
  priority        String?
  mainPain        String?      @db.Text
  productInterest String?
  potentialValue  Decimal?     @db.Decimal(14, 2)
  buyingTiming    String?
  urgency         String?
  competitor      String?
  currentProvider String?
  nextStep        String?
  nextStepDueDate DateTime?
  lastContactAt   DateTime?
  createdById     String?
  createdBy       User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdVia      String       @default("manual")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  people         Person[]
  opportunities  Opportunity[]
  activities     Activity[]
  notes          Note[]
  meetings       Meeting[]
  timelineEvents TimelineEvent[]

  @@index([organizationId, name])
  @@index([organizationId, status])
  @@index([createdById])
  @@map("companies")
}

model Person {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId       String?
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  roleTitle       String?
  linkedinUrl     String?
  isDecisionMaker Boolean      @default(false)
  isSponsor       Boolean      @default(false)
  notes           String?      @db.Text
  createdById     String?
  createdBy       User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdVia      String       @default("manual")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  activities                   Activity[]
  notesRel                     Note[]
  opportunitiesAsDecisionMaker Opportunity[] @relation("OpportunityDecisionMaker")
  opportunitiesAsSponsor       Opportunity[] @relation("OpportunitySponsor")

  @@index([organizationId])
  @@index([companyId])
  @@index([email])
  @@index([createdById])
  @@map("people")
}

model Opportunity {
  id                String        @id @default(cuid())
  organizationId    String
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String
  stageId           String
  stage             PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  estimatedValue    Decimal?      @db.Decimal(14, 2)
  probability       Int?
  source            String?
  mainPain          String?       @db.Text
  urgency           String?
  decisionMakerId   String?
  decisionMaker     Person?       @relation("OpportunityDecisionMaker", fields: [decisionMakerId], references: [id], onDelete: SetNull)
  sponsorId         String?
  sponsor           Person?       @relation("OpportunitySponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  nextStep          String?
  nextStepDueDate   DateTime?
  expectedCloseDate DateTime?
  status            String        @default("open")
  lossReason        String?
  createdById       String?
  createdBy         User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdVia        String        @default("manual")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  activities Activity[]
  notes      Note[]
  meetings   Meeting[]

  @@index([organizationId, stageId])
  @@index([organizationId, status])
  @@index([companyId])
  @@index([createdById])
  @@index([nextStepDueDate])
  @@map("opportunities")
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId      String?
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  personId       String?
  person         Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assigneeId     String?
  assignee       TeamMember?  @relation("ActivityAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  type           String
  title          String
  description    String?      @db.Text
  dueDate        DateTime?
  completedAt    DateTime?
  status         String       @default("pending")
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdVia     String       @default("manual")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([companyId])
  @@index([personId])
  @@index([opportunityId])
  @@index([assigneeId])
  @@index([createdById])
  @@map("activities")
}

model Note {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId      String?
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  personId       String?
  person         Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  opportunityId  String?
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title          String?
  body           String       @db.Text
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdVia     String       @default("manual")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([companyId])
  @@index([personId])
  @@index([opportunityId])
  @@index([createdById])
  @@map("notes")
}

// ---------- Views / persistence ----------

model SavedView {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // Compartidas por org en v1; se registra el creador para permisos futuros.
  createdById        String?
  createdBy          User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  name               String
  entityType         EntityType
  filtersJson        Json?
  sortJson           Json?
  visibleColumnsJson Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId, entityType])
  @@map("saved_views")
}

// ---------- Custom fields ----------

model CustomFieldDefinition {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entityType     EntityType
  fieldName      String
  fieldLabel     String
  fieldType      CustomFieldType
  optionsJson    Json?
  isRequired     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  values CustomFieldValue[]

  @@unique([organizationId, entityType, fieldName])
  @@index([organizationId, entityType])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entityType        EntityType
  entityId          String
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  valueText         String?
  valueNumber       Decimal?              @db.Decimal(18, 4)
  valueBoolean      Boolean?
  valueDate         DateTime?
  valueJson         Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([entityType, entityId, fieldDefinitionId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([fieldDefinitionId])
  @@map("custom_field_values")
}

// ---------- Workflows ----------

model Workflow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  description    String?      @db.Text
  triggerEntity  EntityType
  triggerEvent   String
  conditionsJson Json
  actionsJson    Json
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  logs WorkflowLog[]

  @@index([organizationId, triggerEntity, triggerEvent])
  @@index([isActive])
  @@map("workflows")
}

model WorkflowLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  workflowId     String
  workflow       Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  entityType     EntityType
  entityId       String
  status         String
  message        String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([workflowId])
  @@index([entityType, entityId])
  @@map("workflow_logs")
}

// ---------- Integrations ----------

model IntegrationDelivery {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  type                 String
  channel              String
  entityType           EntityType
  entityId             String
  recipientJson        Json
  payloadJson          Json
  dedupeKey            String
  // pending | sent | failed
  status               String       @default("pending")
  attempts             Int          @default(0)
  lastError            String?      @db.Text
  providerResponseJson Json?
  sentAt               DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([organizationId, dedupeKey])
  @@index([status])
  @@index([type])
  @@index([channel])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("integration_deliveries")
}

// ---------- Auth ----------

model User {
  id             String        @id @default(cuid())
  // Nullable SOLO para super-admins sin tenant (CHECK en SQL). Un super-admin
  // puede además pertenecer a una org (ej. el admin de Zalantos).
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  email          String        @unique
  passwordHash   String
  name           String?
  role           Role          @default(MEMBER)
  isActive       Boolean       @default(true)
  isSuperAdmin   Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  teamMember           TeamMember?
  createdCompanies     Company[]
  createdPeople        Person[]
  createdOpportunities Opportunity[]
  createdActivities    Activity[]
  createdNotes         Note[]
  createdSavedViews    SavedView[]
  passwordResetTokens  PasswordResetToken[]

  @@index([organizationId])
  @@map("users")
}

// Catálogo de personas asignables a tareas, definido por el admin. Puede
// incluir personas sin cuenta en el software; el vínculo a User es opcional
// y habilita el filtro "Mis tareas".
model TeamMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  email          String?
  userId         String?      @unique
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedActivities Activity[] @relation("ActivityAssignee")

  @@index([organizationId])
  @@map("team_members")
}

// ---------- Meeting Intelligence ----------

model Meeting {
  id               String           @id @default(cuid())
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunityId    String?
  opportunity      Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title            String
  meetingType      String           @default("discovery")
  meetingDate      DateTime
  // Free-form attendees: [{ name, email?, role? }]. Linking to Person is a later phase.
  participants     Json             @default("[]")
  status           String           @default("open")
  // Origin of the evidence pipeline: manual | audio | video | recall | meet | ...
  sourceType       String           @default("manual")
  rawTranscript    String?          @db.Text
  aiSummary        Json?
  processingStatus ProcessingStatus @default(pending)
  processingError  String?          @db.Text
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  evidence  Evidence[]
  proposals CRMChangeProposal[]

  @@index([organizationId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([processingStatus])
  @@map("meetings")
}

model Evidence {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  meetingId      String
  meeting        Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  // audio | video | pdf | docx | txt | md | transcript
  type           String
  filename       String
  mimeType       String
  // Object key in Cloudflare R2 (empty for inline manual transcripts).
  storagePath    String
  sizeBytes      Int?
  extractedText  String?      @db.Text
  // uploaded | extracting | extracted | failed
  status         String       @default("uploaded")
  uploadedBy     String
  uploadedAt     DateTime     @default(now())

  @@index([organizationId])
  @@index([meetingId])
  @@map("evidence")
}

model CRMChangeProposal {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // Optional since proposals can also originate from the agent chat.
  meetingId       String?
  meeting         Meeting?       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  // meeting | agent | enrichment
  source          String         @default("meeting")
  // Denormalized context (backfilled from the meeting for legacy rows).
  companyId       String?
  opportunityId   String?
  personId        String?
  // Logical refs to the agent chat (no FK, same convention as TimelineEvent.refId).
  chatThreadId    String?
  chatMessageId   String?
  // Logical ref to EntityContextSource when source=enrichment.
  contextSourceId String?
  confidence      Float
  status          ProposalStatus @default(pending)
  // Model that produced the proposal, for audit (e.g. groq/llama-3.3-70b-versatile).
  model           String?
  rawModelOutput  Json?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())

  items CRMChangeItem[]

  @@index([organizationId])
  @@index([meetingId])
  @@index([status])
  @@index([chatThreadId])
  @@index([contextSourceId])
  @@index([personId])
  @@map("crm_change_proposals")
}

// ---------- Entity context enrichment ----------

// Fuente de evidencia ligada a company/person/opportunity (upload hoy;
// linkedin/url/agent mañana). El pipeline normaliza a extractedText.
model EntityContextSource {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // company | person | opportunity
  entityType      EntityType
  entityId        String
  // upload | linkedin | url | manual | agent
  sourceType      String       @default("upload")
  filename        String
  mimeType        String
  // Object key in Cloudflare R2 (empty for inline text sources).
  storagePath     String
  sizeBytes       Int?
  extractedText   String?      @db.Text
  // External URL or provider id (e.g. LinkedIn profile URL).
  externalRef     String?
  // uploaded | extracting | extracted | analyzing | ready | failed
  status          String       @default("uploaded")
  processingError String?      @db.Text
  uploadedBy      String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, status])
  @@map("entity_context_sources")
}

// Perfil IA consolidado por entidad (uno por ficha). Se reescribe/mergea
// en cada análisis; el historial de fuentes vive en EntityContextSource.
model EntityContextProfile {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // company | person | opportunity
  entityType     EntityType
  entityId       String
  summary        String       @db.Text
  // [{ label, value, confidence?, sourceIds? }]
  keyFacts       Json
  // string[] topics/tags
  topics         Json?
  lastAnalyzedAt DateTime
  model          String?
  rawModelOutput Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, entityType, entityId])
  @@index([organizationId])
  @@map("entity_context_profiles")
}

model CRMChangeItem {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  proposalId     String
  proposal       CRMChangeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  // stage_change | create_task | add_contact | link_contact | update_pain |
  // add_note | update_sponsor | update_decision_maker | update_field
  type           String
  // Target entity type: company | opportunity | person | activity | note
  entity         String
  // Logical reference (no FK); null when the item creates a new entity.
  entityId       String?
  beforeValue    Json?
  afterValue     Json?
  // Cadenas legibles calculadas al crear la propuesta (etiqueta + diff textual).
  // Se persisten para poder renderizar el card de revisión desde la DB (p. ej. en
  // la página /agent/proposals) con paridad con el chat. Null en propuestas
  // creadas antes de esta columna.
  label          String?
  before         String?           @db.Text
  after          String?           @db.Text
  confidence     Float
  explanation    String            @db.Text
  // Verbatim quote from the transcript/document/user message that justifies
  // the change (distinct from the free-text explanation).
  evidence       String?           @db.Text
  // Existing person the dedup matched; set on link_contact items.
  duplicateOfId  String?
  approved       Boolean           @default(false)
  // pending | approved | rejected | applied | failed | reverted
  status         String            @default("pending")
  appliedAt      DateTime?
  // What to undo when reverting an applied item:
  // { createdEntityId?, opportunityId?, prevDecisionMakerId?, prevSponsorId? }.
  revertData     Json?
  revertedAt     DateTime?

  @@index([organizationId])
  @@index([proposalId])
  @@map("crm_change_items")
}

// ---------- Agente IA (copiloto) ----------

model AgentChatThread {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String
  title          String?
  // Page context captured when the thread was opened (e.g. company being viewed).
  contextType    EntityType?
  contextId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  messages AgentChatMessage[]

  @@index([organizationId])
  @@index([userId, updatedAt])
  @@map("agent_chat_threads")
}

model AgentChatMessage {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  threadId       String
  thread         AgentChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  // user | assistant
  role           String
  // AI SDK UIMessage.parts stored verbatim so the UI re-renders tool cards on reload.
  parts          Json
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([threadId, createdAt])
  @@map("agent_chat_messages")
}

model AgentAttachment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // Logical ref to AgentChatThread (no FK, mirrors Evidence's storage shape).
  threadId       String
  filename       String
  mimeType       String
  // Object key in R2; empty when R2 isn't configured (text-only fallback).
  storagePath    String
  sizeBytes      Int?
  extractedText  String?      @db.Text
  // uploaded | extracted | failed
  status         String       @default("uploaded")
  uploadedBy     String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([threadId])
  @@map("agent_attachments")
}

// Vincula un chat de Telegram con un usuario del CRM. La organización se deriva
// del usuario. n8n resuelve tenant/usuario por telegramChatId (vía prismaSystem);
// la UI admin lista/gestiona estos vínculos scopeados por org (forOrg).
model TelegramLink {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // String plano sin FK, igual que AgentChatThread.userId.
  userId           String
  telegramChatId   String       @unique
  telegramUsername String?
  // Thread persistente del copiloto para este chat; creado lazy en el 1er mensaje.
  agentThreadId    String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@map("telegram_links")
}

// Código efímero de un solo uso para el handshake de vinculación de Telegram.
model TelegramLinkCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String
  // 6 chars alfanuméricos en mayúscula; TTL corto; single-use.
  code           String       @unique
  expiresAt      DateTime
  used           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("telegram_link_codes")
}

model TimelineEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunityId  String?
  // meeting_created | proposal_applied | note_added | stage_changed | task_created
  type           String
  title          String
  summary        String?      @db.Text
  // Reference back to the source record (meeting | proposal | note | ...).
  refType        String?
  refId          String?
  actorId        String?
  metadata       Json?
  occurredAt     DateTime     @default(now())

  @@index([organizationId])
  @@index([companyId, occurredAt])
  @@index([opportunityId])
  @@map("timeline_events")
}
